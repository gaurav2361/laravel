{
  "$schema": "https://www.schemastore.org/package.json",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:ssr": "vite build && vite build --ssr",
    "dev": "vite",
    "check": "npx @biomejs/biome check --no-errors-on-unmatched --files-ignore-unknown=true",
